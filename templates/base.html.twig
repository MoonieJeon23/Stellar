<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Stellar{% endblock %}</title>
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        
        {% block stylesheets %}
        <style>
            /* Effet de changement de couleur au survol pour le bouton dégradé */
            .btn-stellar {
                background: linear-gradient(90deg, #ffcc00, #ff8800);
                color: #000;
                transition: transform 0.3s ease, box-shadow 0.3s ease;
                border: none;
            }

            .btn-stellar:hover {
                transform: scale(1.05);
                color: #000;
                box-shadow: 0 4px 15px rgba(255, 136, 0, 0.4);
                background: linear-gradient(90deg, #ffdd33, #ffaa00); /* Légèrement plus clair au survol */
            }
        </style>
        {% endblock %}
    </head>
    <body class="d-flex flex-column min-vh-100 bg-light"> 
        
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3" href="{{ path('app_home') }}">⭐ STELLAR</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link active" href="{{ path('app_home') }}">Accueil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Événements</a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <a href="#" class="btn btn-link text-white text-decoration-none px-3">Connexion</a>
                        
                        <a href="#" class="btn rounded-pill px-4 fw-bold btn-stellar">
                            S'inscrire
                        </a>
                    </div>
                </div>
            </div>
        </nav>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="py-4 bg-white border-top mt-auto">
            <div class="container text-center">
                <p class="text-muted mb-0 small">&copy; 2026 Stellar Project - Madagascar</p>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>