{% extends 'base.html.twig' %}

{% block body %}
<section class="position-relative overflow-hidden text-center text-white bg-dark mb-5">
    <div style="
        background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), 
                    url('https://images.unsplash.com/photo-1492684223066-81342ee5ff30?q=80&w=2070&auto=format&fit=crop'); 
        background-size: cover; 
        background-position: center; 
        padding: 120px 0;">
        
        <div class="container">
            <h1 class="display-2 fw-bold text-uppercase mb-4" style="letter-spacing: 2px;">
                De grands souvenirs <br> commencent ici!
            </h1>
            
            <div class="d-flex justify-content-center gap-3">
                <a href="#events" class="btn btn-lg px-4 rounded-pill fw-bold" 
                   style="background: linear-gradient(90deg, #ffcc00, #ff8800); color: #000; border: none;">
                    Découvrir
                </a>
                <a href="#" class="btn btn-outline-light btn-lg px-4 rounded-pill fw-bold">
                    En savoir plus
                </a>
            </div>
        </div>
    </div>
</section>

<div class="container mt-4" id="events">
    <div class="d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="fw-bold mb-0">Événements à venir</h1>
            <p class="text-muted">Découvrez les meilleures expériences dans votre ville</p>
        </div>
        <button class="btn btn-outline-dark btn-sm d-none d-md-block">Filtrer par date</button>
    </div>

    <div class="row g-4">
        {% for event in events %}
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm overflow-hidden" style="border-radius: 12px;">
                    {# Gestion dynamique de l'image #}
                    {% if event.imageUrl %}
                        <img src="{{ event.imageUrl }}" class="card-img-top" alt="{{ event.name }}" style="height: 180px; object-fit: cover;">
                    {% else %}
                        <div style="height: 180px; background-color: #f8f9fa; display: flex; align-items: center; justify-content: center;">
                            <span class="text-muted small">Aucune image pour {{ event.name }}</span>
                        </div>
                    {% endif %}
                    
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge" style="background: linear-gradient(90deg, #ffcc00, #ff8800); color: #000;">Spectacle</span>
                            <small class="text-muted fw-bold text-uppercase">Bientôt</small>
                        </div>
                        
                        <h5 class="card-title fw-bold mb-1">{{ event.name }}</h5>
                        <p class="card-text text-muted small mb-3">
                            {{ event.description|slice(0, 90) }}...
                        </p>
                        
                        <div class="d-grid">
                            <a href="#" class="btn btn-dark fw-bold" style="border-radius: 8px; background-color: #222;">Réserver ma place</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <p class="text-muted italic">Aucun événement n'est disponible pour le moment.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}